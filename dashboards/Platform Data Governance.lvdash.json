{
  "datasets": [
    {
      "name": "stale_tables",
      "displayName": "Stale Tables",
      "queryLines": [
        "SELECT\n",
        "  full_table_name,\n",
        "  max_updated_at\n",
        "FROM\n",
        "  admin.shared.retention_compliance\n",
        "WHERE\n",
        "  max_updated_at < NOW() - INTERVAL 24 HOURS\n",
        "  OR max_updated_at IS NULL\n",
        "ORDER BY\n",
        "  max_updated_at ASC NULLS FIRST"
      ]
    },
    {
      "name": "non_compliant_tables",
      "displayName": "Non-Compliant Tables",
      "queryLines": [
        "SELECT\n",
        "  table_catalog,\n",
        "  table_schema,\n",
        "  table_name,\n",
        "  insertion_status,\n",
        "  freshness_status,\n",
        "  retention_status,\n",
        "  max_updated_at\n",
        "FROM\n",
        "  admin.shared.retention_compliance\n",
        "WHERE\n",
        "  insertion_status = 'NON-COMPLIANT'\n",
        "  OR freshness_status = 'NON-COMPLIANT'\n",
        "  OR retention_status = 'NON-COMPLIANT'\n",
        "ORDER BY\n",
        "  table_catalog,\n",
        "  table_schema"
      ]
    },
    {
      "name": "compliance_metrics",
      "displayName": "Compliance Metrics",
      "config": {
        "version": "1.1",
        "source": "admin.shared.retention_compliance",
        "dimensions": [
          {
            "name": "table_catalog",
            "expr": "table_catalog"
          },
          {
            "name": "table_schema",
            "expr": "table_schema"
          }
        ],
        "measures": [
          {
            "name": "total_tables",
            "expr": "COUNT(*)"
          },
          {
            "name": "fully_compliant_tables",
            "expr": "COUNT(CASE WHEN insertion_status = 'COMPLIANT' AND freshness_status = 'COMPLIANT' AND retention_status = 'COMPLIANT' THEN 1 END)"
          },
          {
            "name": "non_compliant_tables",
            "expr": "COUNT(CASE WHEN insertion_status = 'NON-COMPLIANT' OR freshness_status = 'NON-COMPLIANT' OR retention_status = 'NON-COMPLIANT' THEN 1 END)"
          },
          {
            "name": "compliance_pct",
            "expr": "ROUND(MEASURE(fully_compliant_tables) * 100.0 / MEASURE(total_tables), 1)"
          },
          {
            "name": "stale_tables",
            "expr": "COUNT(CASE WHEN max_updated_at < NOW() - INTERVAL 24 HOURS OR max_updated_at IS NULL THEN 1 END)"
          },
          {
            "name": "never_updated",
            "expr": "COUNT(CASE WHEN max_updated_at IS NULL THEN 1 END)"
          },
          {
            "name": "stale_pct",
            "expr": "ROUND(MEASURE(stale_tables) * 100.0 / MEASURE(total_tables), 1)"
          }
        ]
      }
    }
  ],
