{
  "datasets": [
    {
      "name": "audit_kpis",
      "displayName": "Audit KPIs",
      "queryLines": [
        "SELECT\n",
        "  COUNT(CASE\n",
        "    WHEN event_date >= current_date() - 7\n",
        "     AND service_name = 'unityCatalog'\n",
        "     AND action_name = 'generateTemporaryTableCredential'\n",
        "     AND (request_params['full_name_arg'] LIKE 'silver.%'\n",
        "       OR request_params['full_name_arg'] LIKE 'gold.%')\n",
        "  THEN 1 END) AS pii_access_7d,\n",
        "  COUNT(DISTINCT CASE\n",
        "    WHEN event_date >= current_date() - 7\n",
        "     AND service_name = 'unityCatalog'\n",
        "     AND action_name = 'generateTemporaryTableCredential'\n",
        "     AND (request_params['full_name_arg'] LIKE 'silver.%'\n",
        "       OR request_params['full_name_arg'] LIKE 'gold.%')\n",
        "  THEN user_identity.email END) AS unique_users_7d,\n",
        "  COUNT(CASE\n",
        "    WHEN event_date >= current_date() - 7\n",
        "     AND response.status_code IS NOT NULL\n",
        "     AND response.status_code != '200'\n",
        "     AND action_name IN ('login', 'tokenLogin', 'oidcTokenExchange', 'serviceAccountLogin')\n",
        "  THEN 1 END) AS failed_auth_7d,\n",
        "  COUNT(CASE\n",
        "    WHEN action_name IN ('updatePermissions', 'updateSharePermissions',\n",
        "                         'grantPermission', 'revokePermission')\n",
        "  THEN 1 END) AS permission_changes_30d\n",
        "FROM system.access.audit\n",
        "WHERE event_date >= current_date() - 30"
      ]
    },
    {
      "name": "pii_access",
      "displayName": "PII Table Access",
      "queryLines": [
        "SELECT\n",
        "  event_time,\n",
        "  user_identity.email                       AS user_email,\n",
        "  request_params['full_name_arg']            AS table_name,\n",
        "  source_ip_address,\n",
        "  response.status_code\n",
        "FROM system.access.audit\n",
        "WHERE event_date >= current_date() - 7\n",
        "  AND service_name = 'unityCatalog'\n",
        "  AND action_name = 'generateTemporaryTableCredential'\n",
        "  AND (\n",
        "    request_params['full_name_arg'] LIKE 'silver.%'\n",
        "    OR request_params['full_name_arg'] LIKE 'gold.%'\n",
        "  )\n",
        "ORDER BY event_time DESC\n",
        "LIMIT 1000"
      ]
    },
    {
      "name": "pii_access_by_user",
      "displayName": "PII Access by User",
      "queryLines": [
        "SELECT\n",
        "  user_identity.email AS user_email,\n",
        "  COUNT(*)            AS access_count\n",
        "FROM system.access.audit\n",
        "WHERE event_date >= current_date() - 7\n",
        "  AND service_name = 'unityCatalog'\n",
        "  AND action_name = 'generateTemporaryTableCredential'\n",
        "  AND (\n",
        "    request_params['full_name_arg'] LIKE 'silver.%'\n",
        "    OR request_params['full_name_arg'] LIKE 'gold.%'\n",
        "  )\n",
        "GROUP BY user_identity.email\n",
        "ORDER BY access_count DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "pii_access_by_day",
      "displayName": "PII Access by Day",
      "queryLines": [
        "SELECT\n",
        "  event_date,\n",
        "  COUNT(*) AS access_count\n",
        "FROM system.access.audit\n",
        "WHERE event_date >= current_date() - 7\n",
        "  AND service_name = 'unityCatalog'\n",
        "  AND action_name = 'generateTemporaryTableCredential'\n",
        "  AND (\n",
        "    request_params['full_name_arg'] LIKE 'silver.%'\n",
        "    OR request_params['full_name_arg'] LIKE 'gold.%'\n",
        "  )\n",
        "GROUP BY event_date\n",
        "ORDER BY event_date ASC"
      ]
    },
    {
      "name": "failed_auth",
      "displayName": "Failed Auth Events",
      "queryLines": [
        "SELECT\n",
        "  event_time,\n",
        "  user_identity.email  AS user_email,\n",
        "  action_name,\n",
        "  source_ip_address,\n",
        "  response.status_code,\n",
        "  response.error_message\n",
        "FROM system.access.audit\n",
        "WHERE event_date >= current_date() - 7\n",
        "  AND response.status_code IS NOT NULL\n",
        "  AND response.status_code != '200'\n",
        "  AND action_name IN ('login', 'tokenLogin', 'oidcTokenExchange', 'serviceAccountLogin')\n",
        "ORDER BY event_time DESC\n",
        "LIMIT 500"
      ]
    },
    {
      "name": "permission_changes",
      "displayName": "Permission Changes",
      "queryLines": [
        "SELECT\n",
        "  event_time,\n",
        "  user_identity.email                     AS user_email,\n",
        "  action_name,\n",
        "  request_params['securable_type']        AS object_type,\n",
        "  request_params['full_name_arg']         AS object_name,\n",
        "  response.status_code\n",
        "FROM system.access.audit\n",
        "WHERE event_date >= current_date() - 30\n",
        "  AND action_name IN (\n",
        "    'updatePermissions', 'updateSharePermissions',\n",
        "    'grantPermission', 'revokePermission'\n",
        "  )\n",
        "ORDER BY event_time DESC\n",
        "LIMIT 500"
      ]
    }
  ],
